# Runtime
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
DATABASE_URL=postgresql://banknow:banknow@localhost:5432/banknow?schema=public
SESSION_PEPPER=replace-with-a-random-32-byte-or-longer-secret
FIELD_ENCRYPTION_KEY=replace-with-a-base64-encoded-32-byte-key
APP_NAME=BANK NOW
DEFAULT_CURRENCY=KES
# Explicit session policy: 30-minute inactivity and 30-day absolute lifetime.
SESSION_IDLE_MINUTES=30
SESSION_ABSOLUTE_HOURS=720
# Hard timeout for outbound payment-provider HTTP requests.
PROVIDER_HTTP_TIMEOUT_MS=10000
# Number of reverse proxies whose X-Forwarded-For values are trusted. Use 0
# when the application is reached directly and configure this explicitly in production.
TRUSTED_PROXY_HOPS=1
# Used only by the authenticated maintenance endpoint. Generate at least 32 random characters.
OPERATIONS_SECRET=replace-with-a-random-32-byte-or-longer-secret

# E-mail. Resend is required in production for verification and password-recovery mail.
RESEND_API_KEY=
EMAIL_FROM=Bank Now <no-reply@example.com>

# Card payments (Visa and Mastercard through Stripe)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# PayPal Orders v2
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_ENV=sandbox

# Safaricom Daraja / M-Pesa
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://your-public-domain.example.com/api/webhooks/mpesa
MPESA_CALLBACK_SECRET=replace-with-a-random-32-byte-or-longer-secret
MPESA_ENV=sandbox

# Bank transfer instructions. A regulated banking partner must supply these values.
BANK_TRANSFER_BANK_NAME=
BANK_TRANSFER_ACCOUNT_NAME=
BANK_TRANSFER_ACCOUNT_NUMBER=
BANK_TRANSFER_BRANCH=
